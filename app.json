{
  "expo": {
    "name": "Fitness & Muscles",
    "slug": "fitness-and-muscles",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "fitnessandmuscles",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fitnessandmuscles.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow Fitness & Muscles to access your photos so you can set a profile picture."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1A1A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.fitnessandmuscles.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-image",
      "expo-secure-store",
      "expo-font",
      "expo-localization",
      "expo-sharing",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d060dc12-d544-4b41-8f51-af4dec980f53"
      }
    },
    "owner": "ahmedmuhammedelsaid"
  }
}
